{
  "hooks": [
    {
      "event": "on_file_save",
      "match": "src/**/*.py",
      "agent": "azure-python-code-reviewer",
      "description": "Run Python code review on any saved Python source file",
      "options": {
        "severity_threshold": "MAJOR",
        "auto_fix": false
      }
    },
    {
      "event": "on_file_save",
      "match": "**/*.tf",
      "agent": "azure-terraform-risk-analyzer",
      "description": "Run Terraform risk analysis on any saved .tf file",
      "options": {
        "severity_threshold": "MAJOR",
        "auto_fix": false
      }
    },
    {
      "event": "on_pr_open",
      "match": "**/*.py",
      "agent": "azure-python-code-reviewer",
      "description": "Run full Python code review when a PR touches Python files",
      "options": {
        "severity_threshold": "MINOR",
        "report_path": "docs/reports/pr-review.md"
      }
    },
    {
      "event": "on_pr_open",
      "match": "**/*.py",
      "agent": "azure-python-security-auditor",
      "description": "Run Python security audit when a PR touches Python files",
      "options": {
        "report_path": "docs/reports/pr-security.md"
      }
    },
    {
      "event": "on_pr_open",
      "match": "**/*.tf",
      "agent": "azure-terraform-risk-analyzer",
      "description": "Run Terraform risk analysis when a PR touches .tf files",
      "options": {
        "severity_threshold": "MINOR",
        "report_path": "docs/reports/pr-terraform-review.md"
      }
    },
    {
      "event": "on_pr_open",
      "match": "**/*.tf",
      "agent": "azure-terraform-auditor",
      "description": "Run Terraform security audit when a PR touches .tf files",
      "options": {
        "report_path": "docs/reports/pr-terraform-security.md"
      }
    },
    {
      "event": "on_branch_create",
      "match": "feature/**",
      "agent": "azure-python-project-planner",
      "description": "Prompt Python planning when a feature branch is created",
      "options": {
        "output_dir": "docs/plans"
      }
    },
    {
      "event": "on_branch_create",
      "match": "infra/**",
      "agent": "azure-terraform-planner",
      "description": "Prompt Terraform planning when an infra branch is created",
      "options": {
        "output_dir": "docs/plans"
      }
    },
    {
      "event": "pre_commit",
      "match": "src/**/*.py",
      "agent": "azure-python-security-auditor",
      "description": "Block commit if Python security auditor finds REJECTED status",
      "options": {
        "block_on": "REJECTED"
      }
    },
    {
      "event": "pre_commit",
      "match": "**/*.tf",
      "agent": "azure-terraform-auditor",
      "description": "Block commit if Terraform auditor finds REJECTED status",
      "options": {
        "block_on": "REJECTED"
      }
    },
    {
      "event": "on_test_fail",
      "agent": "azure-python-code-implementer",
      "description": "Invoke Python implementer when tests fail to attempt a fix",
      "options": {
        "max_retries": 2
      }
    }
  ]
}
